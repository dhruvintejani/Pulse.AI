APP_NAME=Pulse AI API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=pulse_ai
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
BACKEND_CORS_ALLOW_CREDENTIALS=true

INTERNAL_JWT_SECRET=change-this-in-production
INTERNAL_JWT_ALGORITHM=HS256
INTERNAL_JWT_EXPIRES_MINUTES=15

RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_HEALTH=60/minute

LOG_LEVEL=INFO
LOG_JSON=false
